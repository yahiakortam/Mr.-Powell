# Your Discord bot token from the Discord Developer Portal
TOKEN=your_bot_token_here

# The ID of the channel where welcome messages will be sent
# Enable Developer Mode in Discord, then right-click the channel and select "Copy Channel ID"
WELCOME_CHANNEL_ID=your_welcome_channel_id_here

# Your Discord server ID
# Enable Developer Mode in Discord, then right-click your server icon and select "Copy Server ID"
GUILD_ID=your_guild_id_here
